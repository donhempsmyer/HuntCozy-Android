<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/text_add_location_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Hunting Location"
            android:textStyle="bold"
            android:textSize="18sp" />

        <EditText
            android:id="@+id/edit_location_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Location name (e.g. North Ridge Stand)"
            android:inputType="textPersonName" />

        <EditText
            android:id="@+id/edit_location_lat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Latitude (e.g. 44.500)"
            android:inputType="numberDecimal|numberSigned" />

        <EditText
            android:id="@+id/edit_location_lon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Longitude (e.g. -89.500)"
            android:inputType="numberDecimal|numberSigned" />

        <!-- Optional future fields:
             - Notes
             - Access type
             - Private/Public, etc.
        -->

    </LinearLayout>
</ScrollView>