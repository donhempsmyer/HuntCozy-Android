<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardUseCompatPadding="true"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#40FFFFFF"
    app:cardBackgroundColor="#33000000"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Name + optional "Current" pill -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/text_location_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Back Ridge Stand"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/text_location_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Current"
                android:textSize="11sp"
                android:textColor="@android:color/black"
                android:background="@drawable/bg_location_badge"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Coordinates -->
        <TextView
            android:id="@+id/text_location_coords"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="44.5000, -88.5000"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:alpha="0.85" />

        <!-- Meta / hint -->
        <TextView
            android:id="@+id/text_location_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tap to set as current hunting location"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:alpha="0.7" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>