<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardUseCompatPadding="true"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="#20FFFFFF"
    app:cardBackgroundColor="#88000000"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/text_gear_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lofted insulated jacket"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/text_gear_zone_layer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TORSO · INSULATION"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/text_gear_material"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Synthetic insulation"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/text_gear_attributes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ins 8 • Wind 4 • Water 3 • Breath 4"
            android:textColor="@android:color/white" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>