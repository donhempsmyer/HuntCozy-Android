<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardUseCompatPadding="true"
    app:cardBackgroundColor="#33FFFFFF">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:minWidth="96dp">

        <!-- e.g. "Mon 12/09" -->
        <TextView
            android:id="@+id/text_forecast_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mon 12/09"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- e.g. "23° / 36°" -->
        <TextView
            android:id="@+id/text_forecast_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="23° / 36°"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- e.g. "Precip 0.10 in · Snow 0.0 in" -->
        <TextView
            android:id="@+id/text_forecast_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Precip 0.10 in · Snow 0.0 in"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Optional marker (can stay mostly empty) -->
        <TextView
            android:id="@+id/text_forecast_marker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text=""
            android:textColor="@android:color/white"
            android:textSize="10sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>