<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gear name"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/edit_gear_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="e.g. Late-season parka" />

        <!-- Body zone -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Body zone" />

        <Spinner
            android:id="@+id/spinner_body_zone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Layer type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Layer type" />

        <Spinner
            android:id="@+id/spinner_layer_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Material type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Material" />

        <Spinner
            android:id="@+id/spinner_material_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Comfort temperature range -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Comfort temperature range (°F)" />

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <EditText
                android:id="@+id/edit_temp_min"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Min"
                android:inputType="numberSigned" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="to"
                android:layout_marginHorizontal="8dp"
                android:gravity="center_vertical" />

            <EditText
                android:id="@+id/edit_temp_max"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Max"
                android:inputType="numberSigned" />
        </LinearLayout>

        <!-- Attributes section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Attributes (0–10)"
            android:textStyle="bold" />

        <!-- Insulation -->
        <TextView
            android:id="@+id/label_attr_insulation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Insulation" />

        <SeekBar
            android:id="@+id/seek_insulation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="10"
            android:progress="5" />

        <!-- Windproof -->
        <TextView
            android:id="@+id/label_attr_wind"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Windproof" />

        <SeekBar
            android:id="@+id/seek_wind"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="10"
            android:progress="3" />

        <!-- Waterproof -->
        <TextView
            android:id="@+id/label_attr_water"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Waterproof" />

        <SeekBar
            android:id="@+id/seek_water"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="10"
            android:progress="3" />

        <!-- Breathability -->
        <TextView
            android:id="@+id/label_attr_breath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Breathability" />

        <SeekBar
            android:id="@+id/seek_breath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="10"
            android:progress="5" />

        <!-- Noise -->
        <TextView
            android:id="@+id/label_attr_noise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Noise (0 = silent, 10 = loud)" />

        <SeekBar
            android:id="@+id/seek_noise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="10"
            android:progress="3" />

        <!-- Mobility -->
        <TextView
            android:id="@+id/label_attr_mobility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Mobility (0 = stiff, 10 = very mobile)" />

        <SeekBar
            android:id="@+id/seek_mobility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="10"
            android:progress="7" />

    </LinearLayout>
</ScrollView>