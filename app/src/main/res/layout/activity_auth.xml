<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/auth_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background image (match your other screens) -->
    <ImageView
        android:id="@+id/image_auth_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_winter_forest_dark"
        tools:ignore="ContentDescription" />

    <!-- Dark scrim for contrast -->
    <View
        android:id="@+id/auth_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000" />

    <!-- Foreground content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/auth_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal"
            android:fitsSystemWindows="true">

            <!-- App title / branding -->
            <TextView
                android:id="@+id/text_auth_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="26sp"
                android:letterSpacing="0.05"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/text_auth_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in to your HuntCozy account"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:alpha="0.85"
                android:paddingBottom="12dp" />

            <!-- Auth card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_auth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true"
                app:cardBackgroundColor="#33000000"
                app:strokeWidth="1dp"
                app:strokeColor="#40FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Email -->
                    <TextView
                        android:id="@+id/text_auth_email_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:alpha="0.9" />

                    <EditText
                        android:id="@+id/edit_auth_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:inputType="textEmailAddress"
                        android:singleLine="true"
                        android:autofillHints="emailAddress"
                        android:textColor="@android:color/white"
                        android:textColorHint="#80FFFFFF"
                        android:backgroundTint="@android:color/white"
                        android:padding="8dp"
                        tools:text="hunter@example.com" />

                    <!-- Password -->
                    <TextView
                        android:id="@+id/text_auth_password_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Password"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:alpha="0.9" />

                    <EditText
                        android:id="@+id/edit_auth_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:inputType="textPassword"
                        android:singleLine="true"
                        android:autofillHints="password"
                        android:textColor="@android:color/white"
                        android:textColorHint="#80FFFFFF"
                        android:backgroundTint="@android:color/white"
                        android:padding="8dp"
                        android:imeOptions="actionDone"
                        tools:text="hunter123" />

                    <!-- Progress + buttons row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="20dp">

                        <ProgressBar
                            android:id="@+id/progress_auth"
                            style="?android:attr/progressBarStyleSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <Button
                            android:id="@+id/button_auth_sign_in"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign In" />

                        <Button
                            android:id="@+id/button_auth_sign_up"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Sign Up" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</FrameLayout>